// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  MANAGER
  SUPPORT
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

enum PaymentProvider {
  STRIPE
  JAZZCASH
  EASYPAISA
  COD
}

enum ShippingType {
  DOMESTIC
  INTERNATIONAL
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ShippingRateType {
  FLAT
  PER_KG
  FREE
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id                  Int          @id @default(autoincrement())
  name                String       @db.VarChar(100)
  email               String       @unique @db.VarChar(255)
  passwordHash        String?      @db.Text
  role                Role         @default(CUSTOMER)
  provider            AuthProvider @default(LOCAL)
  googleId            String?      @unique @db.VarChar(100)
  avatarUrl           String?      @db.Text
  isEmailVerified     Boolean      @default(false)
  emailVerifyToken    String?      @unique @db.VarChar(255)
  emailVerifyExpiry   DateTime?
  passwordResetToken  String?      @unique @db.VarChar(255)
  passwordResetExpiry DateTime?
  refreshToken        String?      @db.Text
  isActive            Boolean      @default(true)
  deletedAt           DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  wishlists     Wishlist[]
  notifications Notification[]
  inventoryLogs InventoryLog[]
  blogPosts     BlogPost[]
  cart          Cart?

  @@index([email])
  @@index([role])
  @@map("users")
}

model Address {
  id         Int      @id @default(autoincrement())
  label      String   @db.VarChar(50)
  fullName   String   @db.VarChar(100)
  phone      String   @db.VarChar(20)
  street     String   @db.VarChar(255)
  city       String   @db.VarChar(100)
  province   String   @db.VarChar(100)
  postalCode String?  @db.VarChar(20)
  country    String   @default("Pakistan") @db.VarChar(100)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId Int
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(100)
  slug      String     @unique @db.VarChar(120)
  imageUrl  String?    @db.Text
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model Product {
  id                Int           @id @default(autoincrement())
  name              String        @db.VarChar(255)
  slug              String        @unique @db.VarChar(280)
  description       String?       @db.Text
  status            ProductStatus @default(DRAFT)
  isFeatured        Boolean       @default(false)
  localShippingOnly Boolean       @default(false)
  tags              String[]
  seoTitle          String?       @db.VarChar(60)
  seoDescription    String?       @db.VarChar(160)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  variants   ProductVariant[]
  images     ProductImage[]
  reviews    Review[]
  wishlists  Wishlist[]
  orderItems OrderItem[]

  @@index([slug])
  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
  @@map("products")
}

model ProductVariant {
  id            Int         @id @default(autoincrement())
  label         String      @db.VarChar(100)
  sku           String?     @unique @db.VarChar(100)
  price         Decimal     @db.Decimal(10, 2)
  comparePrice  Decimal?    @db.Decimal(10, 2)
  stockQty      Int         @default(0)
  lowStockAlert Int         @default(5)
  stockStatus   StockStatus @default(IN_STOCK)
  isDefault     Boolean     @default(false)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  cartItems     CartItem[]
  orderItems    OrderItem[]
  inventoryLogs InventoryLog[]

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  url       String   @db.Text
  altText   String?  @db.VarChar(255)
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Cart {
  id        Int       @id @default(autoincrement())
  sessionId String?   @unique @db.VarChar(255)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId Int?  @unique
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  items CartItem[]

  @@index([sessionId])
  @@map("carts")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartId    Int
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

model Order {
  id              Int           @id @default(autoincrement())
  orderNumber     String        @unique @db.VarChar(20)
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  subtotal        Decimal       @db.Decimal(10, 2)
  shippingFee     Decimal       @default(0) @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  couponCode      String?       @db.VarChar(50)
  couponDiscount  Decimal?      @db.Decimal(10, 2)
  shippingType    ShippingType  @default(DOMESTIC)
  trackingNumber  String?       @db.VarChar(100)
  courierName     String?       @db.VarChar(100)
  shippedAt       DateTime?
  deliveredAt     DateTime?
  addressSnapshot Json
  customerNote    String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  addressId Int?
  address   Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  items         OrderItem[]
  payment       Payment?
  statusHistory OrderStatusHistory[]
  refund        Refund?
  reviews       Review[]

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id           Int      @id @default(autoincrement())
  productName  String   @db.VarChar(255)
  variantLabel String   @db.VarChar(100)
  unitPrice    Decimal  @db.Decimal(10, 2)
  quantity     Int
  subtotal     Decimal  @db.Decimal(10, 2)
  productImage String?  @db.Text
  createdAt    DateTime @default(now())

  orderId   Int
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int?
  product   Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        Int         @id @default(autoincrement())
  status    OrderStatus
  note      String?     @db.VarChar(255)
  changedBy Int?
  createdAt DateTime    @default(now())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model Payment {
  id          Int             @id @default(autoincrement())
  provider    PaymentProvider
  providerRef String?         @db.VarChar(255)
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("PKR") @db.VarChar(10)
  status      PaymentStatus   @default(UNPAID)
  rawResponse Json?
  paidAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  orderId Int     @unique
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refund  Refund?

  @@index([status])
  @@map("payments")
}

model Refund {
  id          Int      @id @default(autoincrement())
  amount      Decimal  @db.Decimal(10, 2)
  reason      String   @db.Text
  providerRef String?  @db.VarChar(255)
  issuedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  orderId   Int     @unique
  order     Order   @relation(fields: [orderId], references: [id])
  paymentId Int     @unique
  payment   Payment @relation(fields: [paymentId], references: [id])

  @@map("refunds")
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlists")
}

model Review {
  id         Int          @id @default(autoincrement())
  rating     Int
  title      String?      @db.VarChar(150)
  body       String       @db.Text
  status     ReviewStatus @default(PENDING)
  adminReply String?      @db.Text
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId   Int?
  order     Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([userId, productId, orderId])
  @@index([productId])
  @@index([status])
  @@map("reviews")
}

model InventoryLog {
  id        Int      @id @default(autoincrement())
  changeQty Int
  reason    String   @db.VarChar(255)
  createdAt DateTime @default(now())

  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  adminId   Int?
  admin     User?          @relation(fields: [adminId], references: [id])

  @@index([variantId])
  @@map("inventory_logs")
}

model Coupon {
  id          Int        @id @default(autoincrement())
  code        String     @unique @db.VarChar(50)
  description String?    @db.VarChar(255)
  type        CouponType
  value       Decimal    @db.Decimal(10, 2)
  minOrderAmt Decimal?   @db.Decimal(10, 2)
  maxDiscount Decimal?   @db.Decimal(10, 2)
  usesLimit   Int?
  usesCount   Int        @default(0)
  isActive    Boolean    @default(true)
  startsAt    DateTime?
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([code])
  @@map("coupons")
}

model BlogPost {
  id             Int        @id @default(autoincrement())
  title          String     @db.VarChar(255)
  slug           String     @unique @db.VarChar(280)
  excerpt        String?    @db.VarChar(500)
  body           String     @db.Text
  coverImage     String?    @db.Text
  status         BlogStatus @default(DRAFT)
  publishedAt    DateTime?
  seoTitle       String?    @db.VarChar(60)
  seoDescription String?    @db.VarChar(160)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  authorId   Int
  author     User         @relation(fields: [authorId], references: [id])
  categoryId Int
  category   BlogCategory @relation(fields: [categoryId], references: [id])
  tags       BlogTag[]

  @@index([slug])
  @@index([status])
  @@map("blog_posts")
}

model BlogCategory {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(100)
  slug      String     @unique @db.VarChar(120)
  createdAt DateTime   @default(now())
  posts     BlogPost[]

  @@map("blog_categories")
}

model BlogTag {
  id    Int        @id @default(autoincrement())
  name  String     @unique @db.VarChar(50)
  slug  String     @unique @db.VarChar(60)
  posts BlogPost[]

  @@map("blog_tags")
}

model ShippingZone {
  id        Int              @id @default(autoincrement())
  name      String           @db.VarChar(100)
  countries String[]
  rateType  ShippingRateType @default(FLAT)
  baseRate  Decimal          @default(0) @db.Decimal(10, 2)
  perKgRate Decimal?         @db.Decimal(10, 2)
  minDays   Int?
  maxDays   Int?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("shipping_zones")
}

model Banner {
  id        Int       @id @default(autoincrement())
  imageUrl  String    @db.Text
  linkUrl   String?   @db.VarChar(255)
  altText   String?   @db.VarChar(255)
  heading   String?   @db.VarChar(150)
  subtext   String?   @db.VarChar(255)
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("banners")
}

model Faq {
  id        Int      @id @default(autoincrement())
  question  String   @db.VarChar(255)
  answer    String   @db.Text
  category  String   @db.VarChar(100)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(150)
  message   String   @db.Text
  isRead    Boolean  @default(false)
  link      String?  @db.VarChar(255)
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model NewsletterSubscriber {
  id             Int       @id @default(autoincrement())
  email          String    @unique @db.VarChar(255)
  isSubscribed   Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@map("newsletter_subscribers")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(255)
  subject   String   @db.VarChar(255)
  message   String   @db.Text
  isRead    Boolean  @default(false)
  repliedAt DateTime?
  createdAt DateTime @default(now())

  @@map("contact_messages")
}